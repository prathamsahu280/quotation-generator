# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# Secret used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Database. Defaults to a local SQLite file under DATA_DIR if unset.
# For Postgres in the cloud, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/quotations
# DATABASE_URL=

# Where per-user files (letterheads, generated quotations) and the SQLite DB live.
DATA_DIR=./data

# Google Gemini API key for AI mode. Get one at https://aistudio.google.com/apikey
# If empty, AI mode is disabled and the app uses the offline rule-based engine.
GEMINI_API_KEY=

# Gemini model to use. gemini-2.5-flash is a good default; gemini-2.0-flash and
# gemini-flash-latest also work. Pick one your key has quota/access for.
GEMINI_MODEL=gemini-2.5-flash

# Set to "1" to require HTTPS-only (secure) session cookies (use in production).
COOKIE_SECURE=0
