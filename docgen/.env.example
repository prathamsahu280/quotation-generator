# Copy to .env (gitignored). The Next.js backend calls this service with the
# same DOCGEN_SECRET in an X-Docgen-Secret header.

# Shared secret between Next backend and this service. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DOCGEN_SECRET=change-me

# Gemini (AI mode). Empty disables AI; the service then uses the rule-based engine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: explicit path to a LibreOffice binary if not on PATH.
# SOFFICE_BIN=/usr/bin/soffice
